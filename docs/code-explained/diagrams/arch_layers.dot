digraph G {
  bgcolor="#FFF8F2";
  rankdir=TB;
  fontname="Helvetica";
  node [shape=box style="rounded,filled" fontname="Helvetica" fontsize=12 color="#E7D3C1" fillcolor="#FFFFFF" fontcolor="#3D2A1F" margin="0.18,0.10" penwidth=1.4];
  edge [color="#B08968" fontname="Helvetica" fontsize=10 fontcolor="#7A5A44" penwidth=1.3 arrowsize=0.8];
  subgraph cluster_ui { label="UI layer  (Jetpack Compose)"; style="rounded,filled"; fillcolor="#FFE9D8"; fontcolor="#EA580C"; color="#E7D3C1"; fontname="Helvetica";
  "screens" [label="Screens\nDashboard · Stats · Limits\nStreaks · Onboarding · SignIn" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=box];
  "comps" [label="Reusable components\nAppCard · AnimatedCounter\nMoodCharacter · PlatformLogo" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=box];
  }
  subgraph cluster_vm { label="ViewModel layer  (MVVM state holders)"; style="rounded,filled"; fillcolor="#DBEAFE"; fontcolor="#2563EB"; color="#E7D3C1"; fontname="Helvetica";
  "vms" [label="Dashboard / Stats / Streaks /\nLimits / GoogleSignIn ViewModels\n(expose StateFlow)" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=box];
  }
  "repo" [label="UsageRepository\n(single source of truth)" fillcolor="#EDE4FF" fontcolor="#7C3AED" shape=box];
  subgraph cluster_data { label="Data layer"; style="rounded,filled"; fillcolor="#DCFCE7"; fontcolor="#15803D"; color="#E7D3C1"; fontname="Helvetica";
  "room" [label="Room database\nDailyLog · UserLimits · StreakRecord" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=cylinder];
  "prefs" [label="Prefs (SharedPreferences)\n+ AppPreferences (DataStore)" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=box];
  "sync" [label="UsageSyncManager\n→ Firebase Firestore (optional)" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=box];
  }
  subgraph cluster_sys { label="System-driven services & helpers"; style="rounded,filled"; fillcolor="#F3ECE4"; fontcolor="#6B4A33"; color="#E7D3C1"; fontname="Helvetica";
  "reel" [label="ReelCounterService\n(AccessibilityService)" fillcolor="#FFF1E6" fontcolor="#EA580C" shape=box];
  "float" [label="FloatingCounterService\n(overlay + blocking scrim)" fillcolor="#FFF1E6" fontcolor="#EA580C" shape=box];
  "screentime" [label="ScreenTimeHelper\n(UsageStatsManager)" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=box];
  "widget" [label="BrainRotWidget\n(Glance)" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=box];
  }
  screens -> vms [dir=both label="state / events"];
  comps -> screens [style=dotted arrowhead=none];
  vms -> repo;
  repo -> room;
  repo -> sync;
  vms -> prefs;
  reel -> repo [label="increment reels"];
  reel -> float [label="start / block"];
  screentime -> vms [label="live screen time"];
  repo -> widget [style=dashed];
}
