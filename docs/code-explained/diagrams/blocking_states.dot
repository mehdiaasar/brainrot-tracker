digraph G {
  bgcolor="#FFF8F2";
  rankdir=TB;
  fontname="Helvetica";
  node [shape=box style="rounded,filled" fontname="Helvetica" fontsize=12 color="#E7D3C1" fillcolor="#FFFFFF" fontcolor="#3D2A1F" margin="0.18,0.10" penwidth=1.4];
  edge [color="#B08968" fontname="Helvetica" fontsize=10 fontcolor="#7A5A44" penwidth=1.3 arrowsize=0.8];
  "trigger" [label="Trigger:\ncounted reel · 1s heartbeat ·\napp reopened (WINDOW_STATE_CHANGED)" fillcolor="#FFE9D8" fontcolor="#EA580C" shape=box];
  "eval" [label="evaluateBlocking()" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=box];
  "over" [label="Total reels ≥ limit?\n(fallback limit = 30)" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=diamond];
  "ok" [label="Do nothing" fillcolor="#DCFCE7" fontcolor="#15803D" shape=box];
  "mode" [label="Which blocking_mode?" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=diamond];
  "hard" [label="HARD\nFull scrim every time app is\nforegrounded until midnight.\nOnly 'Close app'." fillcolor="#FEE2E2" fontcolor="#DC2626" shape=box];
  "snooze" [label="SNOOZE\n5-min grace stored as\nsnooze_until_<PLATFORM>.\nRe-block when it expires." fillcolor="#FEF3C7" fontcolor="#B45309" shape=box];
  "remind" [label="REMIND\nScrim once per foreground\nsession (sessionDismissed),\ncleared by onTrackedAppLeft." fillcolor="#DBEAFE" fontcolor="#2563EB" shape=box];
  trigger -> eval -> over;
  over -> ok [label="no"];
  over -> mode [label="yes"];
  mode -> hard;
  mode -> snooze;
  mode -> remind;
}
