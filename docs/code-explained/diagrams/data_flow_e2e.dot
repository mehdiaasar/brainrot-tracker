digraph G {
  bgcolor="#FFF8F2";
  rankdir=LR;
  fontname="Helvetica";
  node [shape=box style="rounded,filled" fontname="Helvetica" fontsize=12 color="#E7D3C1" fillcolor="#FFFFFF" fontcolor="#3D2A1F" margin="0.18,0.10" penwidth=1.4];
  edge [color="#B08968" fontname="Helvetica" fontsize=10 fontcolor="#7A5A44" penwidth=1.3 arrowsize=0.8];
  "swipe" [label="User swipes a Reel\nin Instagram" fillcolor="#FFE9D8" fontcolor="#EA580C" shape=box];
  "acc" [label="ReelCounterService\nreceives the event" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=box];
  "conf" [label="Hierarchy scan + debounce\nconfirm one reel" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=box];
  "repo2" [label="UsageRepository\nincrements today's count" fillcolor="#EDE4FF" fontcolor="#7C3AED" shape=box];
  "write" [label="Room writes DailyLog" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=cylinder];
  "fan" [label="Flows emit new value" fillcolor="#DCFCE7" fontcolor="#15803D" shape=box];
  "see" [label="Dashboard counter,\nwidget, mood brain update" fillcolor="#DBEAFE" fontcolor="#2563EB" shape=box];
  "guard" [label="evaluateBlocking +\nmilestone check" fillcolor="#FEE2E2" fontcolor="#DC2626" shape=box];
  "mid" [label="At midnight: streaks +\nsummary + cloud sync" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=box];
  swipe -> acc -> conf -> repo2 -> write -> fan -> see;
  repo2 -> guard [constraint=false];
  fan -> mid [style=dashed];
}
