digraph G {
  bgcolor="#FFF8F2";
  rankdir=TB;
  fontname="Helvetica";
  node [shape=box style="rounded,filled" fontname="Helvetica" fontsize=12 color="#E7D3C1" fillcolor="#FFFFFF" fontcolor="#3D2A1F" margin="0.18,0.10" penwidth=1.4];
  edge [color="#B08968" fontname="Helvetica" fontsize=10 fontcolor="#7A5A44" penwidth=1.3 arrowsize=0.8];
  "evt" [label="Accessibility event\n(CONTENT_CHANGED · VIEW_SCROLLED ·\nWINDOW_STATE_CHANGED)" fillcolor="#FFE9D8" fontcolor="#EA580C" shape=box];
  "gate" [label="Rate-limit gate\n(≥ 0.8s since last tree scan?)" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=box];
  "bfs" [label="BFS scan of view hierarchy\n(AccessibilityNodeInfo)" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=box];
  "detect" [label="Per-platform detector\nIG/Snap: full-screen pager\nYT: signature · TikTok: scroll dir" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=box];
  "debounce" [label="Debounce\n(ignore repeats within 1.2s)" fillcolor="#DCFCE7" fontcolor="#15803D" shape=box];
  "inc" [label="repository.incrementReelCount(platform)" fillcolor="#EDE4FF" fontcolor="#7C3AED" shape=box];
  "db" [label="DailyLog row updated" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=cylinder];
  "ui" [label="UI Flows update\n(Dashboard · widget)" fillcolor="#DBEAFE" fontcolor="#2563EB" shape=box];
  "milestone" [label="Milestone check\n(25/50/.../200 → notification)" fillcolor="#FFFFFF" fontcolor="#3D2A1F" shape=box];
  "block" [label="evaluateBlocking()" fillcolor="#FEE2E2" fontcolor="#DC2626" shape=box];
  evt -> gate -> bfs -> detect -> debounce -> inc -> db;
  db -> ui;
  db -> milestone;
  inc -> block [label="every counted reel"];
  detect -> debounce [label="reel confirmed"];
}
